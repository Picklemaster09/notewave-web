rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net (Default-deny catch-all)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Validation Schema
    function isValidUser(data) {
      return data.userId is string 
        && data.userId == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 200
        && data.tier is string 
        && data.tier in ['free', 'premium']
        && (data.customApiKey == null || (data.customApiKey is string && data.customApiKey.size() <= 1000))
        && (data.language == null || (data.language is string && data.language.size() <= 10));
    }

    // Voice Note Recording Validation Schema
    function isValidRecording(data) {
      return data.id is string 
        && data.id.size() <= 128
        && data.userId is string 
        && data.userId == request.auth.uid
        && data.title is string 
        && data.title.size() <= 200
        && data.duration is number 
        && data.duration >= 0
        && data.transcript is string 
        && data.transcript.size() <= 100000
        && data.ideaSummary is string 
        && data.ideaSummary.size() <= 100000
        && data.actionItems is string 
        && data.actionItems.size() <= 100000
        && data.tags is list 
        && data.tags.size() <= 30
        && (data.tags.size() == 0 || data.tags[0] is string)
        && data.modelUsed is string 
        && data.modelUsed.size() <= 64;
    }

    // Match collections
    match /users/{userId} {
      allow get, delete: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['customApiKey', 'tier', 'language']);

      // 2. Sub-collection of voice recording notes
      match /recordings/{recordingId} {
        allow get, delete: if isOwner(userId);
        
        allow list: if isOwner(userId);

        allow create: if isOwner(userId) 
          && isValidId(recordingId) 
          && isValidRecording(incoming()) 
          && incoming().createdAt == request.time;

        allow update: if isOwner(userId) 
          && isValidId(recordingId) 
          && isValidRecording(incoming())
          && incoming().id == existing().id
          && incoming().userId == existing().userId
          && incoming().duration == existing().duration
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasAny(['title', 'transcript', 'ideaSummary', 'actionItems', 'tags', 'audioData', 'modelUsed']);
      }
    }

    // Utility wrappers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
  }
}
