# ─── FRONTEND (public — safe to include in browser bundle) ───────────────────
# Copy to .env.local for local dev. Never commit real values.

# Auth0 Single Page Application credentials
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.yourdomain.com

# Backend API base URL (empty string = same origin in dev, full URL in prod)
VITE_API_URL=

# ─── BACKEND (secret — never expose to frontend or mobile) ───────────────────
# Set these in your server environment / hosting secrets manager.

# Auth0 API verification (must match the SPA audience above)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.yourdomain.com

# Supabase (service-role key — privileged, never share)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini AI (system-level key used when user hasn't set their own)
GEMINI_API_KEY=your_gemini_api_key

# Optional: user-scoped Gemini key env alias (kept for compatibility)
NoteWave=

# Frontend origin — used for CORS allow-list
FRONTEND_URL=https://app.yourdomain.com

# Server port (defaults to 3000)
PORT=3000

# Set to "production" when deploying
NODE_ENV=development
